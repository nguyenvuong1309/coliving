{
  "name": "CoLiving",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --mode=devDebug --appId=com.coliving.dev",
    "android:dev": "react-native run-android --mode=devDebug --appId=com.coliving.dev",
    "android:prod": "react-native run-android --mode=prodDebug --appId=com.coliving",
    "android:prod:release": "react-native run-android --mode=prodRelease --appId=com.coliving",
    "ios": "react-native run-ios --scheme=CoLiving-Dev --mode=Debug",
    "ios:dev": "react-native run-ios --scheme=CoLiving-Dev --mode=Debug",
    "ios:prod": "react-native run-ios --scheme=CoLiving-Prod --mode=Debug",
    "ios:prod:release": "react-native run-ios --scheme=CoLiving-Prod --mode=Release",
    "start": "react-native start",
    "lint": "eslint .",
    "test": "jest",
    "e2e:ios": "wdio run e2e/config/wdio.ios.conf.ts",
    "e2e:android": "wdio run e2e/config/wdio.android.conf.ts",
    "appium:setup": "appium driver install xcuitest && appium driver install uiautomator2",
    "appium:doctor": "appium driver doctor xcuitest && appium driver doctor uiautomator2"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-google-signin/google-signin": "^13.0.0",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@reduxjs/toolkit": "^2.11.2",
    "@supabase/supabase-js": "^2.101.1",
    "react": "19.2.3",
    "react-hook-form": "^7.72.1",
    "react-native": "0.84.1",
    "@invertase/react-native-apple-authentication": "^2.2.2",
    "react-native-config": "^1.6.1",
    "react-native-gesture-handler": "^2.31.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-mmkv": "^4.3.0",
    "react-native-nitro-modules": "^0.35.3",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-worklets": "^0.8.1",
    "react-redux": "^9.2.0",
    "redux-saga": "^1.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3",
    "@types/mocha": "^10.0.0",
    "@wdio/appium-service": "^8.40.0",
    "@wdio/cli": "^8.40.0",
    "@wdio/local-runner": "^8.40.0",
    "@wdio/mocha-framework": "^8.40.0",
    "@wdio/spec-reporter": "^8.40.0",
    "@wdio/types": "^8.40.0",
    "appium": "^3.0.0",
    "appium-xcuitest-driver": "^10.0.0",
    "appium-uiautomator2-driver": "^7.0.0",
    "ts-node": "^10.9.0",
    "webdriverio": "^8.40.0"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["appium", "appium-ios-tuntap", "sharp"]
  }
}
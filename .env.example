ENV=development
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
APP_NAME=CoLiving Dev
APP_DISPLAY_NAME=CoLiving Dev

# OAuth (lay tu Google Cloud Console)
GOOGLE_WEB_CLIENT_ID=
# iOS only: dao nguoc CLIENT_ID. Vi du: com.googleusercontent.apps.123-abc
GOOGLE_REVERSED_CLIENT_ID=

# Sentry (de trong de tat). Lay tu Sentry > Project Settings > Client Keys (DSN)
SENTRY_DSN=

# RevenueCat (de trong de tat in-app purchase).
# Lay tu RevenueCat Dashboard > Project Settings > API Keys
REVENUECAT_IOS_API_KEY=
REVENUECAT_ANDROID_API_KEY=
